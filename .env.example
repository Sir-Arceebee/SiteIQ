# Copy to .env and fill in your Supabase project values.
#
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api
# - Project URL          → SUPABASE_URL / VITE_SUPABASE_URL
# - anon / publishable   → SUPABASE_PUBLISHABLE_KEY / VITE_SUPABASE_PUBLISHABLE_KEY
# - service_role (SECRET → SUPABASE_SERVICE_ROLE_KEY (server-side import scripts only,
#                          NEVER ship this to the browser)

# Frontend (browser-safe; protected by Row-Level Security)
VITE_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="YOUR-ANON-KEY"
VITE_SUPABASE_PROJECT_ID="YOUR-PROJECT-REF"

# Server-side (used by SSR / API routes)
SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
SUPABASE_PUBLISHABLE_KEY="YOUR-ANON-KEY"

# Required ONLY for the bulk-import scripts in scripts/.
# Keep this OUT of any committed file and out of the browser bundle.
SUPABASE_SERVICE_ROLE_KEY="YOUR-SERVICE-ROLE-KEY"
